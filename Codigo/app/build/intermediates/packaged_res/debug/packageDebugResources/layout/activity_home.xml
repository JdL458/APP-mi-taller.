<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:fillViewport="true"
    android:background="#121212">  <!-- fondo oscuro muy suave -->

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <!-- Foto del alumno con MaterialCardView -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardCornerRadius="70dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1F1F1F"> <!-- card oscuro suave -->

            <ImageView
                android:id="@+id/imgFotoAlumno"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Foto del alumno"
                android:transitionName="fotoAlumno"
                android:src="@drawable/placeholder_foto" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Nombre del alumno -->
        <TextView
            android:id="@+id/txtNombreAlumno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del Alumno"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#BB86FC"
            android:layout_marginBottom="8dp" />

        <!-- DNI -->
        <TextView
            android:id="@+id/txtDni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DNI: 12345678"
            android:textSize="16sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="16dp" />
        <!-- Rol -->
        <TextView
            android:id="@+id/txtRol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rol: Alumno"
            android:textSize="16sp"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <!-- Botón escanear QR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEscanearQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escanear QR"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#6200EE"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"
            android:elevation="4dp" />

        <!-- Título máquinas -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tus máquinas escaneadas:"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#BB86FC"
            android:layout_marginBottom="12dp" />

        <!-- Lista dinámica de máquinas dentro MaterialCardView -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="24dp"
            android:padding="16dp"
            app:cardBackgroundColor="#1F1F1F">

            <LinearLayout
                android:id="@+id/listMaquinas"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Botón cerrar sesión -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#B00020"
             android:textColor="@android:color/white"
            android:padding="12dp"
           android:elevation="4dp" />

    </LinearLayout>
</ScrollView>
